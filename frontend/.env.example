# Public frontend environment variables (safe to commit)
# Set this to your deployed backend base URL with /api/v1 suffix
# Example: https://api.fairlens.mayyanks.app/api/v1
VITE_API_URL=https://api.fairlens.mayyanks.app/api/v1

# Google OAuth Web Client ID from Google Cloud Console
VITE_GOOGLE_CLIENT_ID=

# Local override (optional)
# VITE_API_URL=http://localhost:8001/api/v1
