APP_NAME=FairLens API
APP_VERSION=0.1.0
ENVIRONMENT=staging
DEBUG=false
LOG_LEVEL=INFO
DOCS_ENABLED=true
ALLOWED_HOSTS=["api-dev.fairlens.mayyanks.app"]
SECRET_KEY=<strong-random-dev-secret>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080
DATABASE_URL=<dev-postgres-url>
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
REDIS_URL=<dev-redis-url>
CELERY_BROKER_URL=<dev-redis-url>
CELERY_RESULT_BACKEND=<dev-redis-results-url>
MINIO_ENDPOINT=<dev-minio-endpoint>
MINIO_ACCESS_KEY=<dev-minio-access-key>
MINIO_SECRET_KEY=<dev-minio-secret-key>
MINIO_BUCKET=datasets
MINIO_SECURE=true
GROQ_API_KEY=<groq-key>
GROQ_MODEL=llama-3.1-70b-versatile
GOOGLE_CLIENT_ID=<google-oauth-client-id-dev>
GOOGLE_CLIENT_IDS=["<google-oauth-client-id-dev>"]
CORS_ORIGINS=["https://dev.fairlens.mayyanks.app"]
