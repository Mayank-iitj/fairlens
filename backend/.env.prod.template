# FairLens Production Environment Configuration Template
# Copy this to backend/.env and update all values for production

# =========================================
# Application Settings
# =========================================
APP_NAME=FairLens API
APP_VERSION=2.0
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=WARNING
DOCS_ENABLED=false

# =========================================
# Security (CRITICAL - Update These)
# =========================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secure-secret-key-here-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# =========================================
# Database Configuration
# =========================================
# Format: postgresql+psycopg2://user:password@host:port/database
DATABASE_URL=postgresql+psycopg2://fairlens_user:secure_password@db.example.com:5432/fairlens_prod

# Connection pool settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# =========================================
# Redis Configuration (Caching & Tasks)
# =========================================
REDIS_URL=redis://:secure_password@cache.example.com:6379/0
CELERY_BROKER_URL=redis://:secure_password@cache.example.com:6379/0
CELERY_RESULT_BACKEND=redis://:secure_password@cache.example.com:6379/1

# =========================================
# MinIO / Object Storage (Reports & Data)
# =========================================
MINIO_ENDPOINT=s3.example.com
MINIO_ACCESS_KEY=production_access_key
MINIO_SECRET_KEY=production_secret_key
MINIO_BUCKET=fairlens-reports
MINIO_SECURE=true

# =========================================
# External AI Services
# =========================================
# Groq LLM API Key (for bias detection summarization)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-70b-versatile

# Google OAuth (for authentication)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# =========================================
# CORS Configuration
# =========================================
# Comma-separated list of allowed origins
CORS_ORIGINS=https://app.example.com,https://www.example.com,https://api.example.com

# =========================================
# Allowed Hosts
# =========================================
ALLOWED_HOSTS=app.example.com,www.example.com,api.example.com

# =========================================
# Email Configuration (for notifications)
# =========================================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=noreply@example.com
MAIL_PASSWORD=app_specific_password
MAIL_FROM=noreply@example.com

# =========================================
# Sentry Configuration (Error Tracking)
# =========================================
SENTRY_DSN=https://your_sentry_dsn_here@sentry.io/project_id
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# =========================================
# Monitoring & Logging
# =========================================
# CloudWatch, DataDog, or similar
ENABLE_STRUCTURED_LOGGING=true
LOG_FORMAT=json
LOG_DESTINATION=cloudwatch

# =========================================
# Feature Flags
# =========================================
ENABLE_LLM_BIAS_DETECTION=true
ENABLE_COMPLIANCE_REPORTING=true
ENABLE_AUDIT_MONITORING=true
ENABLE_BATCH_PROCESSING=true

# =========================================
# Rate Limiting
# =========================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_PERIOD=60  # seconds

# =========================================
# Report Generation
# =========================================
REPORT_STORAGE_PATH=/data/reports
REPORT_MAX_SIZE_MB=100
REPORT_RETENTION_DAYS=365

# =========================================
# Database Backup
# =========================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM UTC
BACKUP_RETENTION_DAYS=30

# =========================================
# Audit Trail
# =========================================
ENABLE_AUDIT_LOGGING=true
AUDIT_LOG_RETENTION_DAYS=730  # 2 years

# =========================================
# Compliance Settings
# =========================================
DEFAULT_COMPLIANCE_FRAMEWORK=EEOC
ENABLE_GDPR_COMPLIANCE=true
ENABLE_CCPA_COMPLIANCE=true
ENABLE_HIPAA_COMPLIANCE=false

# =========================================
# Performance Tuning
# =========================================
# Connection timeout
CONNECTION_TIMEOUT=30

# Request timeout
REQUEST_TIMEOUT=300

# Worker threads
WORKER_THREADS=4
WORKER_PROCESSES=2

# =========================================
# Security Headers
# =========================================
ENABLE_SECURITY_HEADERS=true
HSTS_MAX_AGE=31536000
CONTENT_SECURITY_POLICY=default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'

# =========================================
# SSL/TLS Configuration
# =========================================
SSL_ENABLED=true
SSL_CERT_PATH=/etc/ssl/certs/server.crt
SSL_KEY_PATH=/etc/ssl/private/server.key

# =========================================
# API Rate Limiting Per IP
# =========================================
RATE_LIMIT_PER_IP=100
RATE_LIMIT_BURST=200

# =========================================
# Session Configuration
# =========================================
SESSION_TIMEOUT_MINUTES=60
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax

# =========================================
# File Upload Configuration
# =========================================
MAX_UPLOAD_SIZE_MB=100
ALLOWED_FILE_TYPES=.csv,.xlsx,.xls,.json,.parquet

# =========================================
# Notification Configuration
# =========================================
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SLACK_NOTIFICATIONS=false
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# =========================================
# Advanced Settings
# =========================================
# Query optimization
ENABLE_QUERY_OPTIMIZATION=true
QUERY_CACHE_TTL=300  # seconds

# Connection pooling
ENABLE_CONNECTION_POOLING=true
CONNECTION_POOL_RECYCLE=3600

# Async workers for heavy tasks
ASYNC_WORKERS=4

# =========================================
# IMPORTANT PRODUCTION NOTES
# =========================================
# 
# 1. SECURITY KEYS:
#    - Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_urlsafe(32))"
#    - Keep SECRET_KEY secure and don't commit to version control
#    - Rotate keys every 90 days
#
# 2. DATABASE:
#    - Use strong password (min 16 chars, mix upper/lower/numbers/special)
#    - Enable SSL for database connections
#    - Use managed database service (RDS, Cloud SQL, etc.)
#    - Enable automated backups
#    - Test restore procedure regularly
#
# 3. CREDENTIALS:
#    - Never commit .env file to version control
#    - Use environment variables or secrets manager
#    - Rotate API keys every 90 days
#    - Use different keys for each environment
#
# 4. MONITORING:
#    - Enable all monitoring and logging
#    - Configure alerts for critical errors
#    - Set up performance monitoring
#    - Track key business metrics
#
# 5. COMPLIANCE:
#    - Ensure compliance framework matches jurisdiction
#    - Enable audit logging for regulatory requirements
#    - Retain logs for required period
#    - Test data retention policies
#
# 6. BACKUPS:
#    - Test backup restoration monthly
#    - Store backups in separate secure location
#    - Keep backups for compliance period
#    - Document recovery procedures
#
# 7. SSL/TLS:
#    - Use strong cipher suites
#    - Certificate should be valid for 1 year max
#    - Renew before expiration
#    - Monitor certificate expiration
#
# 8. PERFORMANCE:
#    - Monitor database connection usage
#    - Monitor Redis memory usage
#    - Monitor disk space
#    - Monitor CPU and memory
#
# 9. TESTING:
#    - Test complete deployment before going live
#    - Test failover and recovery procedures
#    - Load test to verify performance targets
#    - Security test for vulnerabilities
#
# 10. DOCUMENTATION:
#     - Update runbooks for production
#     - Document access procedures
#     - Create incident response plan
#     - Brief support team on new features
#

# =========================================
# Validation Checklist
# =========================================
# Before deploying to production:
# [ ] All SECRET_KEY values updated
# [ ] All passwords changed from defaults
# [ ] Database connections tested
# [ ] SSL certificates installed
# [ ] CORS origins configured
# [ ] Email service configured
# [ ] Monitoring enabled
# [ ] Backup procedures tested
# [ ] Incident response plan ready
# [ ] Team trained on operations
# [ ] Compliance framework verified
# [ ] All endpoints tested
# [ ] Performance benchmarked
# [ ] Security audit completed
# [ ] Load testing passed
# [ ] Documentation reviewed
