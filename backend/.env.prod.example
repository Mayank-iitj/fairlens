APP_NAME=FairLens API
APP_VERSION=0.1.0
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
DOCS_ENABLED=false
ALLOWED_HOSTS=["api.fairlens.mayyanks.app"]
SECRET_KEY=<strong-random-prod-secret>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080
DATABASE_URL=<prod-postgres-url>
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
REDIS_URL=<prod-redis-url>
CELERY_BROKER_URL=<prod-redis-url>
CELERY_RESULT_BACKEND=<prod-redis-results-url>
MINIO_ENDPOINT=<prod-minio-endpoint>
MINIO_ACCESS_KEY=<prod-minio-access-key>
MINIO_SECRET_KEY=<prod-minio-secret-key>
MINIO_BUCKET=datasets
MINIO_SECURE=true
GROQ_API_KEY=<groq-key>
GROQ_MODEL=llama-3.1-70b-versatile
GOOGLE_CLIENT_ID=<google-oauth-client-id-prod>
GOOGLE_CLIENT_IDS=["<google-oauth-client-id-prod>"]
CORS_ORIGINS=["https://fairlens.mayyanks.app","https://www.fairlens.mayyanks.app"]
