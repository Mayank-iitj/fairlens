APP_NAME=FairLens API
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
DOCS_ENABLED=true
ALLOWED_HOSTS=["localhost","127.0.0.1"]
SECRET_KEY=change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080
DATABASE_URL=postgresql+psycopg2://fairlens:fairlens@postgres:5432/fairlens
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=fairlens
MINIO_SECRET_KEY=fairlens-secret
MINIO_BUCKET=datasets
MINIO_SECURE=false
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile
# Backward-compatible single Google OAuth Web Client ID
GOOGLE_CLIENT_ID=
# Preferred: array of allowed OAuth client IDs for this environment
# Example: ["<local-client-id>","<dev-client-id>","<prod-client-id>"]
GOOGLE_CLIENT_IDS=[]
CORS_ORIGINS=["https://fairlens.mayyanks.app","https://www.fairlens.mayyanks.app","https://dev.fairlens.mayyanks.app","http://localhost:5174","http://127.0.0.1:5174"]
